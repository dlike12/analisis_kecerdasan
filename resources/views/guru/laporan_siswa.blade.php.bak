    </div>
    <div class="p-6">
        <div class="overflow-x-auto">
            <div class="table-responsive"><table class="w-full">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Kelas</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Jumlah Siswa</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sudah Tes</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Belum Tes</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Cluster 1</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Cluster 2</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Cluster 3</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @php
                        $kelasGroups = $siswa->groupBy('kelas');
                        $totalJumlah = 0;
                        $totalSudah = 0;
                        $totalBelum = 0;
                        $totalCluster1 = 0;
                        $totalCluster2 = 0;
                        $totalCluster3 = 0;
                    @endphp
                    @foreach($kelasGroups as $kelas => $siswaKelas)
                    @php
                        $jumlah = $siswaKelas->count();
                        $sudah = $siswaKelas->filter(function($s) { return $s->hasilAnalisis; })->count();
                        $belum = $jumlah - $sudah;
                        $cluster1 = $siswaKelas->filter(function($s) { return $s->hasilAnalisis && $s->hasilAnalisis->cluster == 1; })->count();
                        $cluster2 = $siswaKelas->filter(function($s) { return $s->hasilAnalisis && $s->hasilAnalisis->cluster == 2; })->count();
                        $cluster3 = $siswaKelas->filter(function($s) { return $s->hasilAnalisis && $s->hasilAnalisis->cluster == 3; })->count();
                        
                        $totalJumlah += $jumlah;
                        $totalSudah += $sudah;
                        $totalBelum += $belum;
                        $totalCluster1 += $cluster1;
                        $totalCluster2 += $cluster2;
                        $totalCluster3 += $cluster3;
                    @endphp
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 text-sm font-medium">{{ $kelas }}</td>
                        <td class="px-6 py-4 text-sm">{{ $jumlah }}</td>
                        <td class="px-6 py-4 text-sm">{{ $sudah }}</td>
                        <td class="px-6 py-4 text-sm">{{ $belum }}</td>
                        <td class="px-6 py-4 text-sm">{{ $cluster1 }}</td>
                        <td class="px-6 py-4 text-sm">{{ $cluster2 }}</td>
                        <td class="px-6 py-4 text-sm">{{ $cluster3 }}</td>
                    </tr>
                    @endforeach
                </tbody>
                <tfoot class="bg-gray-100 font-semibold">
                    <tr>
                        <td class="px-6 py-4 text-sm font-bold">TOTAL</td>
                        <td class="px-6 py-4 text-sm font-bold">{{ $totalJumlah }}</td>
                        <td class="px-6 py-4 text-sm font-bold text-green-600">{{ $totalSudah }}</td>
                        <td class="px-6 py-4 text-sm font-bold text-red-600">{{ $totalBelum }}</td>
                        <td class="px-6 py-4 text-sm font-bold text-yellow-600">{{ $totalCluster1 }}</td>
                        <td class="px-6 py-4 text-sm font-bold text-blue-600">{{ $totalCluster2 }}</td>
                        <td class="px-6 py-4 text-sm font-bold text-green-600">{{ $totalCluster3 }}</td>
                    </tr>
                </tfoot>
            </table></div>
        </div>
    </div>
</div>
